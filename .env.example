MYSITE=www.my-domain.com
HY2_ADDR=":10443"
HY2_PASSWORD=123
XRAY_UUID=123
XRAY_VLESS_PORT=443
XRAY_TARGET=www.microsoft.com:443
XRAY_SERVERNAMES="www.microsoft.com","microsoft.com"
XRAY_SHORTIDS="aabbccdd","ffee5678"
XRAY_REALITY_PRIVATE_KEY=123
XRAY_REALITY_MLDSA65_SEED=456

XRAY_IMAGE=ghcr.io/xtls/xray-core:26.1.13
NGINX_IMAGE=nginx:latest
HY2_IMAGE=tobyxdd/hysteria:v2.9.2
SINGBOX_IMAGE=ghcr.io/sagernet/sing-box:1.13.12

SINGBOX_TUIC_PORT=20443
SINGBOX_TUIC_UUID=123
SINGBOX_TUIC_PASSWORD=123

# =============================================================================
# Binary download URLs (used by systemd mode on low-end VPS without Docker)
# Set to empty to skip installing that binary.
# =============================================================================
# Xray: usually a .zip file, e.g. Xray-linux-64.zip
XRAY_DOWNLOAD_URL=https://github.com/XTLS/Xray-core/releases/download/v26.1.13/Xray-linux-64.zip

# Hysteria 2: usually a raw binary, e.g. hysteria-linux-amd64
HY2_DOWNLOAD_URL=https://github.com/apernet/hysteria/releases/download/app/v2.9.2/hysteria-linux-amd64

# sing-box: usually a .tar.gz file
SINGBOX_DOWNLOAD_URL=https://github.com/Sagernet/sing-box/releases/download/v1.13.12/sing-box-1.13.12-linux-amd64.tar.gz

