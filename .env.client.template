# ============ 服务器连接信息 ============
# 默认服务器地址，当某个协议未单独指定服务器时回退使用
SERVER_ADDR=www.my-domain.com

# 各协议独立服务器地址（留空则使用上面的 SERVER_ADDR）
CLIENT_VLESS_SERVER=
CLIENT_HY2_SERVER=
CLIENT_TUIC_SERVER=
CLIENT_ANYTLS_SERVER=

# ============ 协议开关 ============
ENABLE_VLESS=true                     # true/false
ENABLE_HY2=true
ENABLE_TUIC=true
ENABLE_ANYTLS=true

# ============ VLESS + REALITY ============
CLIENT_VLESS_PORT=443
CLIENT_VLESS_UUID=123
CLIENT_VLESS_REALITY_PUBLIC_KEY=123
CLIENT_VLESS_REALITY_SHORT_ID=aabbccdd
# VLESS REALITY 的 tls.server_name 是伪装目标，不是连接地址
CLIENT_VLESS_SERVER_NAME=www.microsoft.com

# ============ Hysteria 2 ============
CLIENT_HY2_PORT=10443
CLIENT_HY2_PASSWORD=123
# Hysteria 2 TLS SNI（留空则使用 CLIENT_HY2_SERVER 的值）
CLIENT_HY2_SERVER_NAME=

# ============ TUIC ============
CLIENT_TUIC_PORT=20443
CLIENT_TUIC_UUID=123
CLIENT_TUIC_PASSWORD=123
# TUIC TLS SNI（留空则使用 CLIENT_TUIC_SERVER 的值）
CLIENT_TUIC_SERVER_NAME=

# ============ AnyTLS ============
CLIENT_ANYTLS_PORT=24443
CLIENT_ANYTLS_USERNAME=anytls_user
CLIENT_ANYTLS_PASSWORD=your-strong-password
# AnyTLS TLS SNI（留空则使用 CLIENT_ANYTLS_SERVER 的值）
CLIENT_ANYTLS_SERVER_NAME=

# ============ 本地代理入站（Mixed: SOCKS5 + HTTP）============
# 监听地址：0.0.0.0 表示局域网内其他设备也可连接；127.0.0.1 仅本机可用
CLIENT_MIXED_LISTEN=0.0.0.0
CLIENT_MIXED_PORT=7890

# ============ Hysteria 2 独立客户端入站 ============
# Hysteria 2 原生客户端自带 SOCKS5 + HTTP 代理入站
CLIENT_HY2_IMAGE=tobyxdd/hysteria:v2.9.2
CLIENT_HY2_SOCKS5_PORT=7891
CLIENT_HY2_HTTP_PORT=7892

# ============ WARP（可选，默认关闭）============
ENABLE_WARP=false
CLIENT_WARP_SERVER=127.0.0.1
CLIENT_WARP_PORT=40000

# ============ Docker 镜像 ============
CLIENT_SINGBOX_IMAGE=ghcr.io/sagernet/sing-box:1.13.12

# ============ DNS ============
REMOTE_DNS=tls://8.8.8.8
LOCAL_DNS=223.5.5.5

# ============ 默认出站 ============
DEFAULT_OUTBOUND=auto                 # auto(urltest) 或指定: vless, hy2, tuic, anytls
